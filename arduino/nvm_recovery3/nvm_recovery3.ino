const uint8_t* fData[6] = { f0, f1, f2, f3, f4, f5 };

void selectMux(uint8_t ch) {
  Wire.beginTransmission(MUX_ADDR);
  Wire.write(1 << ch);
  Wire.endTransmission();
  delay(5);
}

void setup() {
  Wire.begin();
  Serial.begin(9600);
  while (!Serial);
  
  Serial.println(F("=== NVM Recovery v3 ==="));
  Serial.println(F("Using reg=0x00, nvm=0x01"));
  Serial.println(F("Send 'R' to erase+restore all 6 chips."));
  
  while (!Serial.available());
  if (Serial.read() != 'R') {
    Serial.println(F("Aborted."));
    return;
  }
  
  int ok = 0;
  
  for (uint8_t ch = 0; ch < 6; ch++) {
    selectMux(ch);
    
    Serial.print(F("\nCh "));
    Serial.print(ch);
    Serial.print(F(": "));
    
    // Verify chip is there (probe NVM addr 0x01)
    Wire.beginTransmission(0x01);
    if (Wire.endTransmission() != 0) {
      Serial.println(F("NOT FOUND"));
      continue;
    }
    Serial.println(F("found"));
    
    // ---- ERASE all 16 pages via register addr 0x00 ----
    Serial.print(F("  Erase: "));
    bool eraseOK = true;
    for (uint8_t page = 0; page < 16; page++) {
      uint8_t cmd = 0xC0 | page;
      Wire.beginTransmission(0x00);  // Register space
      Wire.write(0xE3);              // ERSE register
      Wire.write(cmd);               // Erase command + page
      uint8_t err = Wire.endTransmission();
      if (err != 0) {
        Serial.print(F("F"));
        Serial.print(page);
        Serial.print(F(" "));
        eraseOK = false;
      } else {
        Serial.print(F("."));
      }
      delay(50);
    }
    Serial.println(eraseOK ? F(" OK") : F(" PARTIAL"));
    
    // Quick check: read NVM page 8 to see if erased
    Wire.beginTransmission(0x01);
    Wire.write(0x80);
    Wire.endTransmission();
    Wire.requestFrom((uint8_t)0x01, (uint8_t)4);
    Serial.print(F("  Post-erase 0x80: "));
    for (int i = 0; i < 4; i++) {
      uint8_t b = Wire.available() ? Wire.read() : 0xEE;
      Serial.print(b, HEX);
      Serial.print(F(" "));
    }
    Serial.println();
    
    // ---- WRITE factory NVM ----
    Serial.print(F("  Write: "));
    bool writeOK = true;
    uint8_t pageBuf[16];
    
    for (uint8_t page = 0; page < 16; page++) {
      uint8_t nvmStart = page * 16;
      
      if (page < 7) {
        memset(pageBuf, 0, 16);
      } else {
        uint8_t off = (page - 7) * 16;
        for (uint8_t i = 0; i < 16; i++) {
          pageBuf[i] = pgm_read_byte(&fData[ch][off + i]);
        }
      }
      
      Wire.beginTransmission(0x01);  // NVM space
      Wire.write(nvmStart);
      for (uint8_t i = 0; i < 16; i++) {
        Wire.write(pageBuf[i]);
      }
      uint8_t err = Wire.endTransmission();
      if (err != 0) {
        Serial.print(F("F"));
        Serial.print(page);
        Serial.print(F(" "));
        writeOK = false;
      } else {
        Serial.print(F("."));
      }
      delay(25);
    }
    Serial.println(writeOK ? F(" OK") : F(" PARTIAL"));
    
    // ---- VERIFY pages 7-15 ----
    Serial.print(F("  Verify: "));
    int bad = 0;
    for (uint8_t page = 7; page < 16; page++) {
      Wire.beginTransmission(0x01);
      Wire.write(page * 16);
      Wire.endTransmission();
      Wire.requestFrom((uint8_t)0x01, (uint8_t)16);
      
      uint8_t off = (page - 7) * 16;
      for (uint8_t i = 0; i < 16; i++) {
        uint8_t got = Wire.available() ? Wire.read() : 0xEE;
        uint8_t exp = pgm_read_byte(&fData[ch][off + i]);
        if (got != exp) {
          bad++;
          if (bad <= 3) {
            Serial.print(F("\n    @0x"));
            Serial.print(page * 16 + i, HEX);
            Serial.print(F(": exp=0x"));
            Serial.print(exp, HEX);
            Serial.print(F(" got=0x"));
            Serial.print(got, HEX);
          }
        }
      }
    }
    
    if (bad == 0) {
      Serial.println(F("PERFECT!"));
      ok++;
    } else {
      Serial.print(F("\n  "));
      Serial.print(bad);
      Serial.println(F(" mismatches"));
    }
  }
  
  // Disable mux
  Wire.beginTransmission(MUX_ADDR);
  Wire.write(0);
  Wire.endTransmission();
  
  Serial.print(F("\nDone: "));
  Serial.print(ok);
  Serial.println(F("/6 restored."));
  Serial.println(F("POWER CYCLE board, then run channel_scanner."));
}

void loop() {}
