/*
 * SLG47004V NVM Recovery — Prime_Maxel-v3
 * 
 * After accidental erase, the I2C slave addresses may have shifted.
 * This sketch scans for GreenPAKs at BOTH old (0x08) and new (0x00) 
 * base addresses, then restores the factory NVM from backup.
 * 
 * Step 1: Scan all channels at both address ranges
 * Step 2: Restore factory NVM to each chip found
 * Step 3: Reset chips to reload from NVM
 */

#include <Wire.h>

#define MUX_ADDR     0x70

// Two possible base addresses (register space)
#define GP_REG_OLD   0x08    // Factory default
#define GP_REG_NEW   0x00    // After NVM erase (SLA bits cleared)
#define GP_NVM_OLD   0x09    // Factory default NVM
#define GP_NVM_NEW   0x01    // After NVM erase

